# Copy to .env and fill in. The Anthropic key is the only required value.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
PORT=4000
# Default model used by stations that don't pin their own.
DEFAULT_MODEL=claude-opus-4-8
# Where PGlite persists its data (real PostgreSQL semantics, embedded in-process).
PGLITE_DIR=./data/pgdata
